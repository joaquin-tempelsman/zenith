# Voice-Managed Inventory System - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================
# OpenAI Configuration (Required)
# ============================================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================================
# Anthropic Configuration (Optional)
# ============================================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ============================================================
# Telegram Bot Configuration (Required)
# ============================================================
# Get your bot token from: https://t.me/botfather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ============================================================
# ngrok Configuration (Optional for Development)
# ============================================================
# Get your authtoken from: https://dashboard.ngrok.com/get-started/your-authtoken
# This is optional - ngrok will work without it but with limitations
# With authtoken: longer session times, custom domains, more tunnels
NGROK_AUTHTOKEN=

# ============================================================
# Database Configuration
# ============================================================
# SQLite database path (default: sqlite:///./data/inventory.db)
DATABASE_URL=sqlite:///./data/inventory.db

# ============================================================
# Dashboard Configuration
# ============================================================
# Password for accessing the Streamlit dashboard
DASHBOARD_PASSWORD=your-secure-password-here

# ============================================================
# Application Configuration
# ============================================================
# Host and port for the FastAPI application
APP_HOST=0.0.0.0
APP_PORT=8000

# ============================================================
# GitHub Container Registry (for production deployment)
# ============================================================
# Format: username/repository-name
GITHUB_REPOSITORY=your-username/inventory-system

# ============================================================
# Production Settings (Digital Ocean / Cloud VM)
# ============================================================
# Your domain name (for SSL/HTTPS)
DOMAIN_NAME=inventory.yourdomain.com

# Public URL for webhook (use domain or IP:port)
# Examples:
#   PUBLIC_URL=https://inventory.yourdomain.com
#   PUBLIC_URL=http://123.45.67.89:8000
PUBLIC_URL=

# Email for Let's Encrypt SSL certificates
SSL_EMAIL=your-email@example.com

# ============================================================
# Access Control Configuration
# ============================================================
# When true, users must provide the secret code to use the bot.
# Each environment has its own toggle and code.
ALLOWED_USERS_ONLY_PROD=true
SECRET_CODE_PROD=your-secret-code-here
ALLOWED_USERS_ONLY_DEV=true
SECRET_CODE_DEV=your-dev-secret-code-here

# ============================================================
# Admin Configuration
# ============================================================
# Secret code to grant admin access via /admin <code> in Telegram.
# Admins receive a daily usage report automatically.
ADMIN_SECRET_CODE_PROD=your-admin-secret-code-here
ADMIN_SECRET_CODE_DEV=your-dev-admin-secret-code-here
# UTC hour (0-23) at which the daily report is sent. Default: 21 (9 PM UTC)
DAILY_REPORT_HOUR=21

# ============================================================
# LangSmith Configuration (Optional - for tracing and debugging)
# ============================================================
# Get your API key from: https://smith.langchain.com/settings
# Enable tracing to monitor LangChain agent calls in LangSmith dashboard
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=inventory-system
